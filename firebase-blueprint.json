{
  "entities": {
    "User": {
      "title": "User",
      "description": "A member of the Develoi team.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "developer", "tester", "designer"] },
        "specialty": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A client project managed by Develoi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold"] },
        "clientName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Feature": {
      "title": "Feature",
      "description": "A specific functionality or requirement of a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "testing", "done"] },
        "testScenarios": { "type": "string" },
        "businessRules": { "type": "string" },
        "assignedTo": { "type": "string" },
        "validatedBy": { "type": "string" },
        "isValidated": { "type": "boolean" },
        "validationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a project chat room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "senderId", "text"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Team member profiles."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Client projects."
    },
    "/projects/{projectId}/features/{featureId}": {
      "schema": "Feature",
      "description": "Features and tasks for a specific project."
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history for a project."
    }
  }
}
