generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  uid          String    @id @default(uuid())
  displayName  String
  email        String    @unique
  passwordHash String
  photoURL     String?
  role         String    @default("viewer")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  token        String?   @db.Text
  messages     Message[]
}

model Project {
  id           String    @id @default(uuid())
  name         String
  description  String    @db.Text
  status       String    @default("active")
  clientName   String
  category     String?
  progress     Int       @default(0)
  deadline     DateTime?
  visibility   String    @default("public")
  allowedUsers Json?
  goals        Json?
  financials   String?   @db.Text
  history      String?   @db.Text
  createdAt    DateTime  @default(now())
  features     Feature[]
  messages     Message[]
}

model Feature {
  id          String   @id @default(uuid())
  key         String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String   @db.Text
  status      String   @default("todo")
  priority    String?  @default("medium")
  category    String?
  assignedTo  String?
  type        String   @default("task")
  tags        Json?
  createdAt   DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [uid], onDelete: Cascade)
  senderName String
  text       String   @db.Text
  createdAt  DateTime @default(now())
}

model SiteValues {
  id      Int    @id @default(1)
  mission String @db.Text
  vision  String @db.Text
  values  Json
}

model TeamMember {
  id       String  @id @default(uuid())
  name     String
  role     String
  bio      String? @db.Text
  photoURL String?
  linkedin String?
  github   String?
  order    Int     @default(0)
}

model PortfolioItem {
  id          String  @id @default(uuid())
  title       String
  description String  @db.Text
  category    String?
  imageURL    String?
  link        String?
  order       Int     @default(0)
}

model BlogPost {
  id              String         @id @default(uuid())
  title           String
  slug            String         @unique
  excerpt         String?        @db.Text
  content         String         @db.LongText
  coverImage      String?        @db.LongText
  status          String         @default("draft")
  featured        Boolean        @default(false)
  tags            String?        @db.Text
  views           Int            @default(0)
  readTimeMinutes Int            @default(1)
  publishedAt     DateTime?
  seoTitle        String?
  seoDescription  String?        @db.Text
  seoKeywords     String?
  categoryId      String?
  authorId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  category        BlogCategory?  @relation(fields: [categoryId], references: [id])
  author          BlogAuthor?    @relation(fields: [authorId], references: [id])
  analytics       BlogAnalytics[]
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  color       String     @default("#6366f1")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  posts       BlogPost[]
}

model BlogAuthor {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  bio       String?    @db.Text
  photo     String?    @db.LongText
  role      String?
  linkedin  String?
  isActive  Boolean    @default(true)
  posts     BlogPost[]
}

model BlogAnalytics {
  id     String   @id @default(uuid())
  postId String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  date   DateTime
  views  Int      @default(1)
}

model BlogSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
