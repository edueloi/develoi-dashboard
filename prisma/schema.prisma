generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  uid          String    @id @default(uuid())
  displayName  String
  email        String    @unique
  passwordHash String
  photoURL     String?
  role         String    @default("viewer")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  token        String?   @db.Text
  messages     Message[]
}

model Project {
  id           String    @id @default(uuid())
  name         String
  description  String    @db.Text
  status       String    @default("active")
  clientName   String
  category     String?
  progress     Int       @default(0)
  deadline     DateTime?
  visibility   String    @default("public")
  allowedUsers Json?
  goals        Json?
  financials   String?   @db.Text
  history      String?   @db.Text
  createdAt    DateTime  @default(now())
  features     Feature[]
  sprints      Sprint[]
  messages     Message[]
}

model Feature {
  id          String   @id @default(uuid())
  key         String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId    String?
  sprint      Sprint?  @relation(fields: [sprintId], references: [id])
  title       String
  description String   @db.Text
  status      String   @default("todo")
  priority    String?  @default("medium")
  category    String?
  assignedTo  String?
  type        String   @default("task")
  tags        Json?
  points      Int      @default(1)
  deadline          DateTime?
  activities        String?  @db.Text
  testCases         String?  @db.LongText
  testEvidence      String?  @db.Text
  testObservations  String?  @db.Text
  createdAt         DateTime @default(now())
}

model Sprint {
  id          String    @id @default(uuid())
  name        String
  goal        String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("planned")
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features    Feature[]
  createdAt   DateTime  @default(now())
}

model Message {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [uid], onDelete: Cascade)
  senderName String
  text       String   @db.Text
  createdAt  DateTime @default(now())
}

model SiteValues {
  id      Int    @id @default(1)
  mission String @db.Text
  vision  String @db.Text
  values  Json
}

model TeamMember {
  id       String  @id @default(uuid())
  name     String
  role     String
  bio      String? @db.Text
  photoURL String? @db.LongText
  linkedin String?
  github   String?
  order    Int     @default(0)
}

model PortfolioItem {
  id          String  @id @default(uuid())
  title       String
  description String  @db.Text
  category    String?
  imageURL    String?
  link        String?
  order       Int     @default(0)
}

model BlogPost {
  id              String         @id @default(uuid())
  title           String
  slug            String         @unique
  excerpt         String?        @db.Text
  content         String         @db.LongText
  coverImage      String?        @db.LongText
  status          String         @default("draft")
  featured        Boolean        @default(false)
  tags            String?        @db.Text
  views           Int            @default(0)
  readTimeMinutes Int            @default(1)
  publishedAt     DateTime?
  seoTitle        String?
  seoDescription  String?        @db.Text
  seoKeywords     String?
  categoryId      String?
  authorId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  category        BlogCategory?  @relation(fields: [categoryId], references: [id])
  author          BlogAuthor?    @relation(fields: [authorId], references: [id])
  analytics       BlogAnalytics[]
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  color       String     @default("#6366f1")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  posts       BlogPost[]
}

model BlogAuthor {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  bio       String?    @db.Text
  photo     String?    @db.LongText
  role      String?
  linkedin  String?
  isActive  Boolean    @default(true)
  posts     BlogPost[]
}

model BlogAnalytics {
  id     String   @id @default(uuid())
  postId String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  date   DateTime
  views  Int      @default(1)
}

model BlogSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Case {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  client          String
  excerpt         String?   @db.Text
  content         String    @db.LongText
  coverImage      String?   @db.LongText
  status          String    @default("draft")
  featured        Boolean   @default(false)
  tags            String?   @db.Text
  views           Int       @default(0)
  likes           Int       @default(0)
  readTimeMinutes Int       @default(1)
  publishedAt     DateTime?
  seoTitle        String?
  seoDescription  String?   @db.Text
  seoKeywords     String?
  segment         String?
  services        String?   @db.Text
  results         String?   @db.Text
  challenge       String?   @db.Text
  solution        String?   @db.Text
  categoryId      String?
  category        CaseCategory? @relation(fields: [categoryId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CaseCategory {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  color       String  @default("#6366f1")
  sortOrder   Int     @default(0)
  cases       Case[]
}

// ─────────────────────────────────────────────────────────────────────────────
// WHATSAPP BOT MÓDULO
// ─────────────────────────────────────────────────────────────────────────────

model WppInstance {
  id           String   @id @default(uuid())
  instanceName String   @db.VarChar(120)
  phone        String?  @db.VarChar(30)
  status       String   @default("not_configured") @db.VarChar(30)
  qrCode       String?  @db.Text
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WppBotConfig {
  id                    String   @id @default(uuid())
  botEnabled            Boolean  @default(false)
  sendWelcome           Boolean  @default(true)
  menuEnabled           Boolean  @default(false)
  menuWelcomeMsg        String?  @db.Text
  menuOptions           String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model WppBotSector {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)           // Ex: "Vendas", "Suporte"
  menuKey      String   @db.VarChar(10)             // Ex: "1", "2"
  description  String?  @db.VarChar(255)
  attendants   String   @db.Text                   // JSON array de atendentes
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations WppConversation[]
}

model WppBotFlowNode {
  id          String   @id @default(uuid())
  type        String   @db.VarChar(30) // welcome, menu, message, sector, input, end
  title       String   @db.VarChar(255)
  content     String?  @db.Text
  options     String?  @db.Text // JSON array [{key:"1", label:"Opção 1", nextNodeId:"xxx"}]
  sectorId    String?  @db.VarChar(36)
  inputVar    String?  @db.VarChar(50)
  nextNodeId  String?  @db.VarChar(36)
  isStart     Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  posX        Int      @default(0)
  posY        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WppConversation {
  id             String    @id @default(uuid())
  sectorId       String?   
  clientPhone    String    @db.VarChar(30)
  clientName     String?   @db.VarChar(255)
  attendantName  String?   @db.VarChar(100)
  status         String    @default("waiting") @db.VarChar(20) // waiting, active, closed
  firstMessage   String?   @db.VarChar(1000)
  closedBy       String?   @db.VarChar(20)  // attendant, client, system
  closedAt       DateTime? 
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sector   WppBotSector?        @relation(fields: [sectorId], references: [id])
  messages WppConversationMessage[]
}

model WppConversationMessage {
  id             String   @id @default(uuid())
  conversationId String   
  fromRole       String   @db.VarChar(20) // client, attendant, bot
  fromPhone      String?  @db.VarChar(30)
  body           String   @db.Text
  sentAt         DateTime @default(now())

  conversation WppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
